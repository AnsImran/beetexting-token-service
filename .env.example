# ==============================================================================
# BEEtexting Token Service — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the real values.
#
#   cp .env.example .env
#
# All values below are REQUIRED unless marked (optional).
# ==============================================================================

# ── BEEtexting OAuth2 Credentials (M2M) ─────────────────────────────────────
BEETEXTING_CLIENT_ID=your-client-id-here
BEETEXTING_CLIENT_SECRET=your-client-secret-here
BEETEXTING_API_KEY=your-api-key-here

# ── BEEtexting Endpoints (optional — defaults shown) ────────────────────────
# BEETEXTING_TOKEN_URL=https://auth.beetexting.com/oauth2/token/
# BEETEXTING_SCOPES=https://com.beetexting.scopes/ReadContact https://com.beetexting.scopes/WriteContact https://com.beetexting.scopes/SendMessage

# ── Token Refresh Behaviour (optional — defaults shown) ─────────────────────
# TOKEN_REFRESH_BUFFER_SECONDS=300       # Refresh 5 min before expiry
# TOKEN_RETRY_ATTEMPTS=3                 # Retry failed fetches up to 3 times
# TOKEN_RETRY_DELAY_SECONDS=2.0          # Base delay between retries (doubles each time)

# ── HTTP Client (optional) ──────────────────────────────────────────────────
# HTTP_TIMEOUT_SECONDS=10.0

# ── Server (optional — defaults shown) ──────────────────────────────────────
# APP_HOST=127.0.0.1                     # Bind to localhost only (internal service)
# APP_PORT=8100
# LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR | CRITICAL
