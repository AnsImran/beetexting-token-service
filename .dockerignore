# ──────────────────────────────────────────────────────────────────────────────
# .dockerignore — keep the build context minimal and safe.
#
# Anything listed here will NOT be sent to the Docker daemon when building,
# so it cannot leak into the image.  This is the last line of defence against
# accidentally baking secrets into a container.
# ──────────────────────────────────────────────────────────────────────────────

# ── Secrets — never copy into image ────────────────────────────────────────
.env
.env.*
!.env.example
credentials/
*.pem
*.key

# ── Git ────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ── Test / coverage / lint ─────────────────────────────────────────────────
tests/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/
.mypy_cache/

# ── uv ─────────────────────────────────────────────────────────────────────
.uv/
uv.lock

# ── Docs (not needed at runtime) ───────────────────────────────────────────
docs/
README.md

# ── IDE & OS ───────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── Docker files themselves (not needed inside the image) ──────────────────
Dockerfile
.dockerignore
docker-compose.yml
.github/
